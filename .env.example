# Monday.com API Token (for frontend direct API calls - fallback)
VITE_MONDAY_API_TOKEN=your_monday_api_token

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: n8n webhook for auto Discord follow-up when admin clicks Follow Up
VITE_N8N_FOLLOWUP_WEBHOOK_URL=your_n8n_followup_webhook_url

# Existing n8n chat URL (fallback for follow-up webhook if dedicated URL not set)
VITE_N8N_CHAT_URL=your_n8n_chat_url